{
  "project": {
    "name": "loss-aware-synthetic-data-generation-strong",
    "random_seed": 42
  },
  "paths": {
    "data_dir": "data",
    "raw_data_dir": "data/raw",
    "processed_data_dir": "data/processed",
    "synthetic_data_dir": "data/synthetic",
    "results_dir": "results",
    "reports_dir": "reports"
  },
  "dataset": {
    "name": "folktables_acs_income",
    "test_size": 0.2,
    "max_rows": null,
    "target_column": "income_gt_50k",
    "folktables": {
      "survey_year": "2018",
      "horizon": "1-Year",
      "survey": "person",
      "states": [
        "CA"
      ]
    }
  },
  "models": {
    "baseline_classifiers": [
      "logistic_regression",
      "random_forest",
      "gradient_boosting"
    ]
  },
  "synthetic_generation": {
    "sample_size": 50000,
    "fit_max_rows": 50000,
    "generators": {
      "gaussian_copula": {
        "enabled": true
      },
      "ctgan": {
        "enabled": true,
        "epochs": 100,
        "batch_size": 500,
        "enable_gpu": true
      },
      "tvae": {
        "enabled": true,
        "epochs": 100,
        "batch_size": 500,
        "enable_gpu": true
      }
    }
  },
  "privacy_evaluation": {
    "max_real_rows": 20000,
    "max_synthetic_rows": 20000,
    "exact_match_tolerance": 1e-9
  },
  "loss_aware_selection": {
    "candidate_count": 5,
    "weights": {
      "distribution_mismatch": 0.4,
      "correlation_distortion": 0.3,
      "downstream_degradation": 0.3
    },
    "privacy": {
      "min_median_dcr": 1.5,
      "max_exact_match_rate": 0.0,
      "max_membership_advantage": 0.2
    }
  }
}
